<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Khối camera + overlay chồng đúng lên nhau -->
    <FrameLayout
        android:id="@+id/camera_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.camera.view.PreviewView
            android:id="@+id/streaming_preview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:scaleType="fillCenter" />

        <vn.edu.usth.myapplication.BoundingBoxOverlayView
            android:id="@+id/streaming_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:clickable="false"
            android:focusable="false" />
    </FrameLayout>

    <!-- Nút back góc trên trái -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_streaming_back"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="← Back"
        android:textColor="#FFFFFF"
        app:backgroundTint="#88000000"
        app:cornerRadius="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Hint phía dưới -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_streaming_hint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        app:cardBackgroundColor="#CC000000"
        app:cardCornerRadius="16dp"
        app:layout_constraintBottom_toTopOf="@id/btn_save_detected"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/txt_streaming_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="Hướng camera vào vật thể..."
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:gravity="center" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Nút Save góc dưới phải -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_save_detected"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="💾 Lưu từ"
        android:enabled="false"
        app:cornerRadius="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>